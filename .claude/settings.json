{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": {"tool_name": {"regex": "^(Bash|Edit|Write|TaskCreate|NotebookEdit|mcp__.*)$"}},
        "hooks": [
          {
            "type": "command",
            "command": "lsp-max-cli gate check"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": {"tool_name": {"regex": "^(Bash|Edit|Write)$"}},
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/sac/lsp-max && lsp-max-cli diagnostic snapshot 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
